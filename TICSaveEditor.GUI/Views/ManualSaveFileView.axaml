<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:TICSaveEditor.GUI.ViewModels"
             x:Class="TICSaveEditor.GUI.Views.ManualSaveFileView"
             x:DataType="vm:ManualSaveFileViewModel">
    <Grid ColumnDefinitions="220,1,*">
        <Grid Grid.Column="0" RowDefinitions="Auto,*">
            <TextBlock Grid.Row="0" Text="Slots" FontWeight="Bold" Margin="2,0,0,4"/>
            <ListBox Grid.Row="1"
                     ItemsSource="{CompiledBinding Slots}"
                     SelectedItem="{CompiledBinding SelectedSlot}">
                <ListBox.ItemTemplate>
                    <DataTemplate x:DataType="vm:SaveSlotViewModel">
                        <StackPanel>
                            <TextBlock Text="{CompiledBinding SlotLabel}"/>
                            <TextBlock Text="{CompiledBinding TitleDisplay}"
                                       FontSize="11" Opacity="0.75"
                                       TextTrimming="CharacterEllipsis"
                                       IsVisible="{CompiledBinding IsNotEmpty}"/>
                            <TextBlock Text="(empty)" FontSize="11" Opacity="0.5"
                                       IsVisible="{CompiledBinding IsEmpty}"/>
                        </StackPanel>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </Grid>

        <Rectangle Grid.Column="1" Fill="#444"/>

        <ContentControl Grid.Column="2" Content="{CompiledBinding SelectedSlot}" Margin="6"/>
    </Grid>
</UserControl>
