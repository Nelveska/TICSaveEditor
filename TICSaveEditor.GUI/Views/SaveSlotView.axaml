<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:TICSaveEditor.GUI.ViewModels"
             xmlns:v="using:TICSaveEditor.GUI.Views"
             x:Class="TICSaveEditor.GUI.Views.SaveSlotView"
             x:DataType="vm:SaveSlotViewModel">
    <DockPanel LastChildFill="True">
        <Border DockPanel.Dock="Top" Padding="0,0,0,8">
            <Grid ColumnDefinitions="Auto,*" RowDefinitions="Auto,Auto,Auto,Auto">
                <TextBlock Grid.Row="0" Grid.Column="0" Text="Slot: " FontWeight="Bold"/>
                <TextBlock Grid.Row="0" Grid.Column="1" Text="{CompiledBinding SlotLabel}"/>

                <TextBlock Grid.Row="1" Grid.Column="0" Text="Title: " FontWeight="Bold"/>
                <TextBlock Grid.Row="1" Grid.Column="1" Text="{CompiledBinding Title}" TextTrimming="CharacterEllipsis"/>

                <TextBlock Grid.Row="2" Grid.Column="0" Text="Hero: " FontWeight="Bold"/>
                <TextBlock Grid.Row="2" Grid.Column="1" Text="{CompiledBinding HeroName}"/>

                <TextBlock Grid.Row="3" Grid.Column="0" Text="Saved / Playtime: " FontWeight="Bold"/>
                <StackPanel Grid.Row="3" Grid.Column="1" Orientation="Horizontal">
                    <TextBlock Text="{CompiledBinding SaveTimestampDisplay}"/>
                    <TextBlock Text="  ·  "/>
                    <TextBlock Text="{CompiledBinding PlaytimeDisplay}"/>
                </StackPanel>
            </Grid>
        </Border>

        <Border DockPanel.Dock="Top" Padding="0,4,0,8" IsVisible="{CompiledBinding IsNotEmpty}">
            <StackPanel Orientation="Horizontal" Spacing="6">
                <TextBlock Text="Bulk actions:" FontWeight="Bold" VerticalAlignment="Center" Margin="0,0,4,0"/>
                <Button Content="Set all to level…"
                        Command="{CompiledBinding SetAllToLevelCommand}"
                        ToolTip.Tip="Set every populated unit in this slot to a chosen level (1–99)."/>
                <Button Content="Max all job points"
                        Command="{CompiledBinding MaxAllJobPointsCommand}"
                        ToolTip.Tip="Set every populated unit's job points to the maximum value."/>
                <Button Content="Learn all abilities (current job)"
                        Command="{CompiledBinding LearnAllAbilitiesCurrentJobCommand}"
                        ToolTip.Tip="Mark every ability of each unit's current job as learned."/>
            </StackPanel>
        </Border>

        <v:UnitListView DataContext="{CompiledBinding}"/>
    </DockPanel>
</UserControl>
