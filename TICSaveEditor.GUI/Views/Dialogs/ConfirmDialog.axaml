<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:TICSaveEditor.GUI.ViewModels.Dialogs"
        x:Class="TICSaveEditor.GUI.Views.Dialogs.ConfirmDialog"
        x:DataType="vm:ConfirmDialogViewModel"
        Title="{CompiledBinding Title}"
        Width="480" Height="200"
        CanResize="False"
        WindowStartupLocation="CenterOwner">
    <DockPanel LastChildFill="True" Margin="16">
        <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button Content="{CompiledBinding CancelText}" Width="100" Margin="0,0,8,0"
                    IsCancel="True" Click="OnCancel"/>
            <Button Content="{CompiledBinding ConfirmText}" Width="120"
                    IsDefault="True" Click="OnConfirm"/>
        </StackPanel>
        <TextBlock Text="{CompiledBinding Message}" TextWrapping="Wrap"/>
    </DockPanel>
</Window>
